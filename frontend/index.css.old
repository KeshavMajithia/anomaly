/* ── Reset + Base ──────────────────────────────────────────────────── */
*,
*::before,
*::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
}

:root {
    --bg: #06080f;
    --bg2: #0c1019;
    --bg3: #131825;
    --bg4: #1a2035;
    --border: #1e293b;
    --border-2: #2a3654;
    --text: #e2e8f0;
    --text-2: #94a3b8;
    --text-3: #64748b;
    --accent: #6366f1;
    --accent-2: #818cf8;
    --accent-3: #a5b4fc;
    --flagged: #ef4444;
    --flagged-2: #fca5a5;
    --classified: #22c55e;
    --classified-2: #86efac;
    --dismissed: #64748b;
    --discover: #f59e0b;
    --discover-2: #fcd34d;
    --radius: 14px;
    --radius-sm: 8px;
    --shadow: 0 8px 32px rgba(0, 0, 0, 0.5);
    --glow: 0 0 20px rgba(99, 102, 241, 0.15);
}

html {
    font-size: 15px;
    scroll-behavior: smooth;
}

body {
    background: var(--bg);
    color: var(--text);
    font-family: 'Inter', -apple-system, sans-serif;
    min-height: 100vh;
    overflow-x: hidden;
}

/* Animated background grid */
body::before {
    content: '';
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background:
        radial-gradient(circle at 20% 20%, rgba(99, 102, 241, 0.03) 0%, transparent 50%),
        radial-gradient(circle at 80% 80%, rgba(168, 85, 247, 0.03) 0%, transparent 50%);
    pointer-events: none;
    z-index: 0;
}

/* ── Header ─────────────────────────────────────────────────────────── */
.header {
    background: linear-gradient(135deg, rgba(12, 16, 25, 0.95) 0%, rgba(26, 16, 64, 0.95) 100%);
    border-bottom: 1px solid var(--border);
    padding: 1rem 2rem;
    position: sticky;
    top: 0;
    z-index: 100;
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
}

.header-inner {
    max-width: 1440px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
}

.logo {
    display: flex;
    align-items: center;
    gap: 1rem;
}

.logo-icon {
    font-size: 2.2rem;
    filter: drop-shadow(0 0 16px rgba(99, 102, 241, 0.5));
    animation: pulse-glow 3s ease-in-out infinite;
}

@keyframes pulse-glow {

    0%,
    100% {
        filter: drop-shadow(0 0 12px rgba(99, 102, 241, 0.4));
    }

    50% {
        filter: drop-shadow(0 0 24px rgba(99, 102, 241, 0.7));
    }
}

.logo h1 {
    font-size: 1.3rem;
    font-weight: 700;
    background: linear-gradient(135deg, #818cf8 0%, #c084fc 50%, #f0abfc 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    letter-spacing: -0.02em;
}

.logo p {
    font-size: 0.75rem;
    color: var(--text-3);
    margin-top: 2px;
    letter-spacing: 0.02em;
}

.header-stats {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
}

.stat-pill {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid var(--border);
    border-radius: 999px;
    padding: 0.3rem 0.75rem;
    font-size: 0.78rem;
    color: var(--text-2);
    font-weight: 500;
    transition: all 0.2s;
    backdrop-filter: blur(4px);
}

.stat-pill:hover {
    border-color: var(--accent);
}

.stat-pill.flagged {
    border-color: rgba(239, 68, 68, 0.4);
    color: var(--flagged-2);
}

.stat-pill.discover {
    border-color: rgba(245, 158, 11, 0.4);
    color: var(--discover);
}

/* ── Tabs ────────────────────────────────────────────────────────────── */
.tabs {
    background: var(--bg2);
    border-bottom: 1px solid var(--border);
    display: flex;
    gap: 0;
    padding: 0 2rem;
    max-width: 100%;
    overflow-x: auto;
    position: relative;
    z-index: 50;
}

.tab {
    background: none;
    border: none;
    color: var(--text-3);
    cursor: pointer;
    font-family: inherit;
    font-size: 0.82rem;
    font-weight: 500;
    padding: 0.9rem 1.3rem;
    border-bottom: 2px solid transparent;
    transition: all 0.25s ease;
    white-space: nowrap;
    position: relative;
}

.tab:hover {
    color: var(--text-2);
    background: rgba(255, 255, 255, 0.02);
}

.tab.active {
    color: var(--accent-2);
    border-bottom-color: var(--accent);
}

.tab.active::after {
    content: '';
    position: absolute;
    bottom: -1px;
    left: 20%;
    right: 20%;
    height: 2px;
    background: var(--accent);
    box-shadow: 0 0 12px rgba(99, 102, 241, 0.6);
    border-radius: 2px;
}

/* ── Main ────────────────────────────────────────────────────────────── */
.main {
    max-width: 1440px;
    margin: 0 auto;
    padding: 1.5rem 2rem;
    position: relative;
    z-index: 10;
}

.tab-content {
    display: none;
    animation: fadeIn 0.3s ease;
}

.tab-content.active {
    display: block;
}

@keyframes fadeIn {
    from {
        opacity: 0;
        transform: translateY(6px);
    }

    to {
        opacity: 1;
        transform: none;
    }
}

.section-header {
    margin-bottom: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
}

.section-header h2 {
    font-size: 1.15rem;
    font-weight: 600;
    letter-spacing: -0.01em;
}

.section-header p {
    color: var(--text-3);
    font-size: 0.82rem;
}

/* ── Object Card ─────────────────────────────────────────────────────── */
.object-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    gap: 0.8rem;
}

.discoveries-grid {
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
}

.obj-card {
    background: linear-gradient(145deg, var(--bg2) 0%, var(--bg3) 100%);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.1rem;
    transition: all 0.25s ease;
    cursor: pointer;
    position: relative;
    overflow: hidden;
}

.obj-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: transparent;
    transition: background 0.3s;
}

.obj-card:hover {
    border-color: var(--border-2);
    transform: translateY(-2px);
    box-shadow: var(--glow);
}

.obj-card:hover::before {
    background: linear-gradient(90deg, var(--accent), var(--accent-2));
}

.obj-card.triage-flagged {
    border-left: 3px solid var(--flagged);
}

.obj-card.triage-flagged::before {
    background: linear-gradient(90deg, var(--flagged), transparent);
}

.obj-card.triage-discover {
    border-left: 3px solid var(--discover);
}

.obj-card.triage-discover::before {
    background: linear-gradient(90deg, var(--discover), transparent);
}

.obj-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    margin-bottom: 0.6rem;
    gap: 0.5rem;
}

.obj-oid {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.78rem;
    color: var(--accent-3);
    word-break: break-all;
    font-weight: 500;
}

.score-badge {
    font-size: 0.72rem;
    font-weight: 700;
    padding: 0.2rem 0.55rem;
    border-radius: 999px;
    white-space: nowrap;
    flex-shrink: 0;
    letter-spacing: 0.02em;
}

.score-high {
    background: rgba(239, 68, 68, 0.15);
    color: var(--flagged-2);
    box-shadow: 0 0 8px rgba(239, 68, 68, 0.15);
}

.score-med {
    background: rgba(245, 158, 11, 0.12);
    color: var(--discover-2);
}

.score-low {
    background: rgba(99, 102, 241, 0.12);
    color: var(--accent-2);
}

.obj-meta {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.25rem 0.4rem;
    margin-bottom: 0.6rem;
}

.meta-item {
    font-size: 0.75rem;
    color: var(--text-3);
}

.meta-item b {
    color: var(--text-2);
    font-weight: 500;
}

.obj-reason {
    font-size: 0.72rem;
    color: var(--text-3);
    background: rgba(255, 255, 255, 0.02);
    border-radius: var(--radius-sm);
    padding: 0.3rem 0.5rem;
    margin-bottom: 0.6rem;
    border: 1px solid var(--border);
}

.simbad-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    font-size: 0.72rem;
    padding: 0.18rem 0.45rem;
    border-radius: 6px;
    margin-bottom: 0.6rem;
    font-weight: 500;
}

.simbad-no {
    background: rgba(239, 68, 68, 0.08);
    color: var(--flagged-2);
    border: 1px solid rgba(239, 68, 68, 0.15);
}

.simbad-yes {
    background: rgba(34, 197, 94, 0.08);
    color: var(--classified-2);
    border: 1px solid rgba(34, 197, 94, 0.15);
}

.feedback-buttons {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
    margin-top: 0.6rem;
}

.btn {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    padding: 0.35rem 0.75rem;
    border-radius: var(--radius-sm);
    border: none;
    cursor: pointer;
    font-family: inherit;
    font-size: 0.78rem;
    font-weight: 600;
    transition: all 0.2s ease;
    position: relative;
    overflow: hidden;
}

.btn::after {
    content: '';
    position: absolute;
    inset: 0;
    background: rgba(255, 255, 255, 0);
    transition: background 0.2s;
}

.btn:hover::after {
    background: rgba(255, 255, 255, 0.05);
}

.btn:active {
    transform: scale(0.97);
}

.btn-interesting {
    background: rgba(34, 197, 94, 0.1);
    color: var(--classified-2);
    border: 1px solid rgba(34, 197, 94, 0.2);
}

.btn-interesting:hover {
    border-color: rgba(34, 197, 94, 0.5);
    box-shadow: 0 0 12px rgba(34, 197, 94, 0.1);
}

.btn-noise {
    background: rgba(100, 116, 139, 0.1);
    color: var(--text-3);
    border: 1px solid var(--border);
}

.btn-noise:hover {
    border-color: var(--text-3);
}

.btn-classify {
    background: rgba(99, 102, 241, 0.1);
    color: var(--accent-2);
    border: 1px solid rgba(99, 102, 241, 0.2);
}

.btn-classify:hover {
    border-color: rgba(99, 102, 241, 0.5);
    box-shadow: 0 0 12px rgba(99, 102, 241, 0.1);
}

.btn-secondary {
    background: var(--bg3);
    color: var(--text-2);
    border: 1px solid var(--border);
    padding: 0.45rem 0.9rem;
    align-self: flex-start;
}

.btn-secondary:hover {
    border-color: var(--accent);
    color: var(--accent-2);
    box-shadow: var(--glow);
}

/* ── Table ───────────────────────────────────────────────────────────── */
.object-table-wrap {
    overflow-x: auto;
    border-radius: var(--radius);
    border: 1px solid var(--border);
}

.object-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.8rem;
}

.object-table thead th {
    background: var(--bg3);
    border-bottom: 1px solid var(--border);
    color: var(--text-3);
    font-weight: 600;
    letter-spacing: 0.06em;
    padding: 0.65rem 0.8rem;
    text-align: left;
    font-size: 0.7rem;
    text-transform: uppercase;
    position: sticky;
    top: 0;
}

.object-table tbody td {
    border-bottom: 1px solid rgba(30, 41, 59, 0.5);
    color: var(--text-2);
    padding: 0.55rem 0.8rem;
    vertical-align: middle;
}

.object-table tbody tr {
    transition: background 0.15s;
}

.object-table tbody tr:hover td {
    background: rgba(99, 102, 241, 0.03);
}

.object-table .mono {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.72rem;
    color: var(--accent-3);
}

/* ── Stats Cards ─────────────────────────────────────────────────────── */
.stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(170px, 1fr));
    gap: 0.8rem;
}

.stats-card {
    background: linear-gradient(145deg, var(--bg2) 0%, var(--bg3) 100%);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.3rem;
    text-align: center;
    transition: all 0.2s;
    position: relative;
    overflow: hidden;
}

.stats-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 30%;
    right: 30%;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--accent), transparent);
    opacity: 0.3;
}

.stats-card:hover {
    border-color: var(--border-2);
    transform: translateY(-1px);
}

.stats-card.flagged {
    border-color: rgba(239, 68, 68, 0.2);
}

.stats-card.flagged::before {
    background: linear-gradient(90deg, transparent, var(--flagged), transparent);
}

.stats-card.classified {
    border-color: rgba(34, 197, 94, 0.2);
}

.stats-card.classified::before {
    background: linear-gradient(90deg, transparent, var(--classified), transparent);
}

.stats-card.dismissed {
    border-color: rgba(100, 116, 139, 0.2);
}

.stats-card.discover {
    border-color: rgba(245, 158, 11, 0.2);
}

.stats-card.discover::before {
    background: linear-gradient(90deg, transparent, var(--discover), transparent);
}

.stats-card.feedback {
    border-color: rgba(99, 102, 241, 0.2);
}

.stats-number {
    font-size: 2.2rem;
    font-weight: 700;
    background: linear-gradient(135deg, #818cf8, #c084fc);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    margin-bottom: 0.2rem;
    line-height: 1.1;
}

.stats-label {
    font-size: 0.8rem;
    color: var(--text-3);
    font-weight: 500;
}

/* ── Empty State ─────────────────────────────────────────────────────── */
.empty-state {
    text-align: center;
    padding: 3rem;
    color: var(--text-3);
}

.empty-state span {
    font-size: 3rem;
    display: block;
    margin-bottom: 0.8rem;
}

.empty-state p {
    font-size: 0.95rem;
}

/* ── Rescan / Retrain Banner ─────────────────────────────────────────── */
.rescan-banner {
    background: rgba(99, 102, 241, 0.06);
    border: 1px solid rgba(99, 102, 241, 0.2);
    border-radius: var(--radius-sm);
    color: var(--accent-2);
    font-size: 0.82rem;
    margin-bottom: 1rem;
    padding: 0.65rem 1rem;
    font-weight: 500;
}

/* ── Modal ───────────────────────────────────────────────────────────── */
.modal-overlay {
    background: rgba(0, 0, 0, 0.8);
    bottom: 0;
    left: 0;
    right: 0;
    top: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    position: fixed;
    z-index: 1000;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    animation: fadeIn 0.2s ease;
}

.modal {
    background: linear-gradient(145deg, var(--bg2) 0%, var(--bg3) 100%);
    border: 1px solid var(--border-2);
    border-radius: var(--radius);
    max-height: 90vh;
    max-width: 700px;
    overflow-y: auto;
    padding: 1.75rem;
    position: relative;
    width: 92%;
    box-shadow: 0 16px 64px rgba(0, 0, 0, 0.6);
    animation: modalIn 0.3s ease;
}

@keyframes modalIn {
    from {
        opacity: 0;
        transform: scale(0.95) translateY(10px);
    }

    to {
        opacity: 1;
        transform: none;
    }
}

.modal-close {
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid var(--border);
    border-radius: 6px;
    color: var(--text-3);
    cursor: pointer;
    font-size: 0.9rem;
    padding: 0.2rem 0.45rem;
    position: absolute;
    right: 1rem;
    top: 1rem;
    transition: all 0.15s;
}

.modal-close:hover {
    border-color: var(--flagged);
    color: var(--flagged-2);
    background: rgba(239, 68, 68, 0.1);
}

.modal-oid {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.85rem;
    color: var(--accent-2);
    margin-bottom: 0.8rem;
    font-weight: 500;
}

.modal-meta-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.5rem;
    margin-bottom: 1rem;
}

.modal-meta-item {
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    padding: 0.5rem 0.7rem;
}

.modal-meta-item label {
    display: block;
    font-size: 0.65rem;
    color: var(--text-3);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: 0.15rem;
    font-weight: 600;
}

.modal-meta-item span {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--text);
}

/* ── Toast ───────────────────────────────────────────────────────────── */
.toast {
    background: var(--bg3);
    border: 1px solid var(--border-2);
    border-radius: var(--radius-sm);
    bottom: 1.5rem;
    box-shadow: var(--shadow);
    color: var(--text);
    font-size: 0.82rem;
    font-weight: 500;
    padding: 0.65rem 1.1rem;
    position: fixed;
    right: 1.5rem;
    z-index: 2000;
    animation: slideIn 0.3s ease;
    backdrop-filter: blur(8px);
}

@keyframes slideIn {
    from {
        transform: translateX(100%);
        opacity: 0;
    }

    to {
        transform: none;
        opacity: 1;
    }
}

/* ── Responsive ──────────────────────────────────────────────────────── */
@media (max-width: 768px) {
    .header-inner {
        flex-direction: column;
        align-items: flex-start;
    }

    .main {
        padding: 1rem;
    }

    .object-grid {
        grid-template-columns: 1fr;
    }

    .stats-grid {
        grid-template-columns: repeat(2, 1fr);
    }

    .modal-meta-grid {
        grid-template-columns: 1fr;
    }
}